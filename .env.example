# TaskPilot Environment Configuration
# Kopiere diese Datei als .env.dev / .env.integration / .env.prod

# ── PostgreSQL ──────────────────────────────────────────────
TP_DB_HOST=localhost
TP_DB_PORT=5435
TP_DB_USER=taskpilot
TP_DB_PASSWORD=CHANGE_ME
TP_DB_NAME=taskpilot_dev

# ── Auth ────────────────────────────────────────────────────
TP_SECRET_KEY=CHANGE_ME_RANDOM_64_CHARS
TP_OWNER_EMAIL=admin@innosmith.ai
TP_OWNER_PASSWORD=CHANGE_ME
TP_OWNER_DISPLAY_NAME=InnoSmith
TP_DEBUG=true

# ── CORS (JSON-Array) ──────────────────────────────────────
TP_CORS_ORIGINS=["https://tp.innosmith.ai"]

# ── Nanobot WebSocket ──────────────────────────────────────
TP_NANOBOT_WS_URL=ws://127.0.0.1:8765
TP_NANOBOT_WS_TOKEN=CHANGE_ME

# ── LiteLLM Gateway ───────────────────────────────────────
TP_LITELLM_BASE_URL=http://localhost:4000
TP_TRIAGE_MODEL=ollama/qwen3.6:latest

# ── Microsoft Graph API ────────────────────────────────────
TP_GRAPH_TENANT_ID=
TP_GRAPH_CLIENT_ID=
TP_GRAPH_CLIENT_SECRET=
TP_GRAPH_USER_EMAIL=

# ── Pipedrive CRM ─────────────────────────────────────────
TP_PIPEDRIVE_API_TOKEN=
TP_PIPEDRIVE_DOMAIN=innosmith

# ── Toggl Track ───────────────────────────────────────────
TP_TOGGL_API_TOKEN=
TP_TOGGL_WORKSPACE_ID=0

# ── Bexio Buchhaltung ─────────────────────────────────────
TP_BEXIO_API_TOKEN=

# ── LLM Provider API Keys ─────────────────────────────────
TP_OPENAI_API_KEY=
TP_ANTHROPIC_API_KEY=
TP_GEMINI_API_KEY=
TP_PERPLEXITY_API_KEY=

# ── Web Search ────────────────────────────────────────────
TP_TAVILY_API_KEY=

# ── SIGNA Strategic Intelligence ──────────────────────────
TP_ISI_HOST=
TP_ISI_DB=
TP_ISI_USER=
TP_ISI_SECRET=
TP_ISI_PORT=5432

# ── InvoiceInsight ────────────────────────────────────────
TP_INVOICEINSIGHT_API_KEY=
TP_INVOICEINSIGHT_URL=http://127.0.0.1:8055/mcp

# ── Unsplash ──────────────────────────────────────────────
TP_UNSPLASH_ACCESS_KEY=

# ── Triage Intervals ──────────────────────────────────────
TP_TRIAGE_INTERVAL_SECONDS=120
TP_CHAT_TRIAGE_INTERVAL_SECONDS=300

# ── Content Converter ─────────────────────────────────────
TP_CONTENTCONVERTER_PATH=/opt/vendor/contentconverter
TP_CONTENTCONVERTER_CCONV_BIN=/usr/local/bin/cconv
TP_PPTX_TEMPLATE_DIR=/opt/vendor/contentconverter/templates

# ── Sandbox ───────────────────────────────────────────────
TP_SANDBOX_IMAGE=taskpilot-sandbox:latest
